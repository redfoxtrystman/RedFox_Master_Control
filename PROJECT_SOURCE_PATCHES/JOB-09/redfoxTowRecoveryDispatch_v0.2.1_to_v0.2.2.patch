+local function chooseAccidentSpotCluster(spots, pickup, requestedCount)
+  if not pickup or not pickup.pos then return nil end
+  local candidates = {}
+  for _, spot in ipairs(spots or {}) do
+    if spot and spot.pos then
+      local d = distance(spot.pos, pickup.pos)
+      if d >= 2.4 and d <= 13.0 then
+        table.insert(candidates, {spot = spot, distance = d})
+      end
+    end
+  end
+  table.sort(candidates, function(a, b) return a.distance < b.distance end)
+
+  local selected = {pickup}
+  for _, candidate in ipairs(candidates) do
+    local separated = true
+    for _, existing in ipairs(selected) do
+      if distance(candidate.spot.pos, existing.pos) < 2.35 then
+        separated = false
+        break
+      end
+    end
+    if separated then table.insert(selected, candidate.spot) end
+    if #selected >= requestedCount then return selected end
+  end
+  return nil
+end
